# Backend Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=decode_age_task_manager
DB_USER=postgres
DB_PASSWORD=your_password_here

# Database URL for migrations (node-pg-migrate)
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:your_password_here@localhost:5432/decode_age_task_manager

# Microsoft Entra ID Configuration
ENTRA_CLIENT_ID=your_client_id_here
ENTRA_CLIENT_SECRET=your_client_secret_here
ENTRA_TENANT_ID=your_tenant_id_here
ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1h

# WebSocket Configuration
WS_PORT=5001

# Frontend Configuration (for reference)
# VITE_API_URL=http://localhost:5000
# VITE_WS_URL=ws://localhost:5001
