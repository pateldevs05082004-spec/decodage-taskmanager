{
  "name": "decode-age-task-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm.cmd run dev:backend\" \"npm.cmd run dev:frontend\"",
    "dev:backend": "cd backend && npm.cmd run dev",
    "dev:frontend": "cd frontend && npm.cmd run dev",
    "hash-password": "cd backend && npm.cmd run hash-password",
    "install:all": "npm.cmd install && cd frontend && npm.cmd install && cd ../backend && npm.cmd install"
  },
  "dependencies": {
    "@vercel/node": "^3.0.0",
    "pg": "^8.11.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "typescript": "^5.3.3",
    "concurrently": "^8.2.2"
  }
}
